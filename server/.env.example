# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Server Port
PORT=5000

# CORS Configuration
# Comma-separated list of allowed origins (frontend URLs)
# In production, add your deployed frontend URL(s)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Email Configuration (Gmail)
# For Gmail, you need to use an App Password, not your regular password
# Instructions to get App Password:
# 1. Go to your Google Account: https://myaccount.google.com/
# 2. Select Security
# 3. Under "Signing in to Google" select 2-Step Verification (must be enabled)
# 4. Go back to Security page and select App passwords
# 5. Select app: Mail, and select device: Other (Custom name)
# 6. Enter "Portfolio Contact Form" and click Generate
# 7. Copy the 16-character password and paste it below (without spaces)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-here

# The email address where contact form messages will be sent
# (usually the same as EMAIL_USER)
RECIPIENT_EMAIL=your-email@gmail.com
