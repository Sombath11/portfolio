# Frontend Environment Variables
# Copy this file to .env and fill in your actual values

# Backend API URL (change this to your production URL when deploying)
REACT_APP_API_URL=http://localhost:5000/contact

# Mailchimp Configuration
# Get these values from your Mailchimp account:
# - REACT_APP_MAILCHIMP_URL: Your Mailchimp audience URL (looks like https://list-manage.com/subscribe/post)
# - REACT_APP_MAILCHIMP_U: Your Mailchimp user ID
# - REACT_APP_MAILCHIMP_ID: Your Mailchimp audience ID
REACT_APP_MAILCHIMP_URL=
REACT_APP_MAILCHIMP_U=
REACT_APP_MAILCHIMP_ID=
